<%# app/views/admin/categories/_form.html.erb %>
<%= form_with model: [ :admin, category ], class: "space-y-4" do |f| %>
  <% if category.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded-lg text-sm">
      <ul class="list-disc list-inside">
        <% category.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 dark:text-stone-300 mb-1" %>
    <%= f.text_field :name,
          class: "w-full px-3 py-2 rounded-lg border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-700 text-stone-900 dark:text-stone-100 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400",
          autofocus: true %>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "bg-teal-700 text-white px-4 py-2 rounded-lg text-sm hover:bg-teal-600 cursor-pointer" %>
    <%= link_to "Cancel", admin_categories_path, class: "text-sm text-gray-500 dark:text-stone-400 hover:text-gray-700 dark:hover:text-stone-200 px-2 py-2" %>
  </div>
<% end %>
