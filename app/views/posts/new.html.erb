<%# app/views/posts/new.html.erb %>
<div class="max-w-2xl mx-auto mt-8 px-4">
  <h1 class="text-2xl font-bold mb-6 dark:text-stone-100">New Post</h1>

  <%= form_with model: @post, class: "space-y-4 bg-white dark:bg-stone-800 border border-gray-200 dark:border-stone-700 rounded-lg p-6" do |f| %>
    <% if @post.errors.any? %>
      <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded text-sm">
        <ul class="list-disc list-inside">
          <% @post.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :category_id, "Category", class: "block text-sm font-medium text-gray-700 dark:text-stone-300" %>
      <%= f.select :category_id,
            @categories.map { |c| [c.name, c.id] },
            { selected: @post.category_id },
            class: "mt-1 block w-full border border-gray-300 dark:border-stone-600 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 bg-white dark:bg-stone-700 text-stone-900 dark:text-stone-100" %>
    </div>
    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-700 dark:text-stone-300" %>
      <%= f.text_field :title, class: "mt-1 block w-full border border-gray-300 dark:border-stone-600 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 bg-white dark:bg-stone-700 text-stone-900 dark:text-stone-100" %>
    </div>
    <div>
      <%= f.label :body, class: "block text-sm font-medium text-gray-700 dark:text-stone-300" %>
      <div data-controller="markdown-preview">
        <div class="flex border-b border-gray-200 dark:border-stone-700 mt-1 mb-2">
          <button type="button"
                  data-markdown-preview-target="writeTab"
                  data-action="click->markdown-preview#showWrite"
                  class="px-4 py-2 text-sm font-medium text-blue-600 border-b-2 border-blue-600 dark:text-blue-400 dark:border-blue-400">Write</button>
          <button type="button"
                  data-markdown-preview-target="previewTab"
                  data-action="click->markdown-preview#showPreview"
                  class="px-4 py-2 text-sm text-gray-500 hover:text-gray-700 dark:text-stone-400 dark:hover:text-stone-200">Preview</button>
        </div>
        <%= f.text_area :body, rows: 8,
              class: "block w-full border border-gray-300 dark:border-stone-600 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 bg-white dark:bg-stone-700 text-stone-900 dark:text-stone-100",
              data: { markdown_preview_target: "textarea" } %>
        <div data-markdown-preview-target="preview"
             class="hidden w-full border border-gray-300 dark:border-stone-600 rounded-md px-3 py-2 text-gray-800 dark:text-stone-200 prose prose-sm max-w-none"></div>
        <p class="text-xs text-gray-400 dark:text-stone-500 mt-1">Markdown supported — **bold**, _italic_, `code`, fenced code blocks</p>
      </div>
    </div>
    <%= f.submit "Create Post", class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 font-medium" %>
  <% end %>
</div>
