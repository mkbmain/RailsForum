<%# app/views/posts/show.html.erb %>
<div class="max-w-3xl mx-auto mt-8 px-4">
  <%= link_to "← Back to Forum", posts_path, class: "text-blue-600 hover:underline text-sm" %>

  <div class="bg-white dark:bg-stone-800 border border-gray-200 dark:border-stone-700 rounded-lg p-6 mt-4">
    <h1 class="text-2xl font-bold dark:text-stone-100"><%= @post.title %></h1>
    <div class="flex items-center gap-2 mt-1">
      <%= link_to @post.category.name,
            posts_path(category: @post.category_id),
            class: "text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-stone-700 text-gray-600 dark:text-stone-300 hover:bg-gray-200 dark:hover:bg-stone-600 category-badge" %>
      <div class="flex items-center gap-1.5">
        <% if @post.user.avatar_url.present? %>
          <%= image_tag @post.user.avatar_url, class: "w-5 h-5 rounded-full", alt: "" %>
        <% else %>
          <span class="w-5 h-5 rounded-full bg-teal-100 dark:bg-teal-900 text-teal-700 dark:text-teal-300 font-semibold flex items-center justify-center text-xs">
            <%= (@post.user.name.presence || "?").first.upcase %>
          </span>
        <% end %>
        <p class="text-sm text-gray-500 dark:text-stone-400">
          <%= @post.user.name %> &middot; <%= time_ago_in_words(@post.created_at) %> ago
        </p>
      </div>
      <% if logged_in? && current_user == @post.user && Time.current - @post.created_at <= EDIT_WINDOW_SECONDS %>
        <%= link_to "Edit", edit_post_path(@post), class: "text-xs text-blue-500 hover:underline ml-auto" %>
      <% end %>
      <% if logged_in? && !@post.removed? %>
        <% already_flagged = current_user.flags.exists?(content_type_id: ContentType::CONTENT_POST, flaggable_id: @post.id) %>
        <% if already_flagged %>
          <span class="text-xs text-gray-400 dark:text-stone-500">Flagged ✓</span>
        <% else %>
          <details class="relative">
            <summary class="text-xs text-gray-400 dark:text-stone-500 hover:text-red-500 cursor-pointer list-none">Flag</summary>
            <div class="absolute right-0 top-5 z-10 bg-white dark:bg-stone-800 border border-gray-200 dark:border-stone-700 rounded-lg shadow-lg p-3 w-48">
              <%= form_with url: post_flags_path(@post), method: :post do |f| %>
                <p class="text-xs font-medium text-gray-700 dark:text-stone-300 mb-2">Report reason</p>
                <% Flag.reasons.each_key do |reason| %>
                  <label class="flex items-center gap-2 text-xs text-gray-600 dark:text-stone-400 mb-1 cursor-pointer">
                    <%= f.radio_button :reason, reason, class: "accent-red-500" %>
                    <%= reason.humanize %>
                  </label>
                <% end %>
                <%= f.submit "Submit", class: "mt-2 w-full bg-red-500 text-white text-xs py-1 rounded hover:bg-red-600 cursor-pointer" %>
              <% end %>
            </div>
          </details>
        <% end %>
      <% end %>
    </div>
    <% if logged_in? && can_moderate?(@post.user) && !@post.removed? %>
      <div class="mt-3 flex gap-3">
        <%= button_to "Remove Post", post_path(@post), method: :delete,
              class: "text-xs text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer",
              data: { confirm: "Remove this post?" } %>
        <%= link_to "Ban User", new_user_ban_path(user_id: @post.user_id),
              class: "text-xs text-orange-600 hover:underline" %>
      </div>
    <% end %>
    <% if @post.removed? %>
      <div class="mt-4 text-gray-400 dark:text-stone-500 italic">[removed by moderator]</div>
      <% if logged_in? && current_user.moderator? %>
        <p class="text-xs text-gray-400 dark:text-stone-500 mt-1">
          Removed by <%= @post.removed_by.name %> on <%= @post.removed_at.strftime("%B %-d, %Y") %>
        </p>
        <%= button_to "Restore", restore_post_path(@post), method: :patch,
              class: "text-xs text-green-600 hover:underline bg-transparent border-0 p-0 cursor-pointer mt-1" %>
      <% end %>
    <% else %>
      <div class="mt-4 text-gray-800 dark:text-stone-200"><%= render_markdown(@post.body) %></div>
      <% if @post.edited? %>
        <p class="text-xs text-gray-400 dark:text-stone-500 mt-2 last-edited-at">last edited at <%= @post.last_edited_at.strftime("%-d %b %Y %H:%M") %></p>
      <% end %>
      <%= turbo_frame_tag reactions_frame_id(@post) do %>
        <%= render "reactions/reactions", reactionable: @post %>
      <% end %>
    <% end %>
  </div>

  <div class="mt-8">
    <%= turbo_stream_from @post, :replies %>
    <%= render partial: "replies/count", locals: { post: @post, count: @reply_count } %>

    <div id="replies-list-<%= @post.id %>">
      <%= render partial: "replies/reply", collection: @replies.first(@take), as: :reply, locals: { post: @post, flagged_reply_ids: @flagged_reply_ids } %>
    </div>

    <div class="flex justify-between mt-4 mb-6">
      <% if @page > 1 %>
        <%= link_to "← Previous", post_path(@post, page: @page - 1, take: @take),
              class: "text-teal-700 hover:underline font-medium text-sm" %>
      <% else %>
        <span></span>
      <% end %>
      <% if @replies.size > @take %>
        <%= link_to "Next →", post_path(@post, page: @page + 1, take: @take),
              class: "text-teal-700 hover:underline font-medium text-sm" %>
      <% end %>
    </div>

    <% if logged_in? %>
      <div class="mt-6 bg-white dark:bg-stone-800 border border-gray-200 dark:border-stone-700 rounded-lg p-4">
        <h3 class="font-medium mb-3 dark:text-stone-100">Leave a Reply</h3>
        <%= form_with model: [@post, @reply], class: "space-y-3" do |f| %>
          <% if @reply.errors.any? %>
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-3 py-2 rounded text-sm">
              <%= @reply.errors.full_messages.to_sentence %>
            </div>
          <% end %>
          <div data-controller="markdown-preview">
            <div class="flex border-b border-gray-200 dark:border-stone-700 mb-2">
              <button type="button"
                      data-markdown-preview-target="writeTab"
                      data-action="click->markdown-preview#showWrite"
                      class="px-4 py-2 text-sm font-medium text-blue-600 border-b-2 border-blue-600 dark:text-blue-400 dark:border-blue-400">Write</button>
              <button type="button"
                      data-markdown-preview-target="previewTab"
                      data-action="click->markdown-preview#showPreview"
                      class="px-4 py-2 text-sm text-gray-500 hover:text-gray-700 dark:text-stone-400 dark:hover:text-stone-200">Preview</button>
            </div>
            <%= f.text_area :body, rows: 4, placeholder: "Write your reply...",
                  class: "w-full border border-gray-300 dark:border-stone-600 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 bg-white dark:bg-stone-700 text-stone-900 dark:text-stone-100",
                  data: { markdown_preview_target: "textarea" } %>
            <div data-markdown-preview-target="preview"
                 class="hidden w-full border border-gray-300 dark:border-stone-600 rounded-md px-3 py-2 text-gray-800 dark:text-stone-200 prose prose-sm max-w-none"></div>
            <p class="text-xs text-gray-400 dark:text-stone-500">Markdown supported — **bold**, _italic_, `code`, fenced code blocks</p>
          </div>
          <%= f.submit "Post Reply", class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 font-medium" %>
        <% end %>
      </div>
    <% else %>
      <p class="mt-6 text-gray-600 dark:text-stone-400 text-sm">
        <%= link_to "Log in", login_path, class: "text-blue-600 hover:underline" %> to reply.
      </p>
    <% end %>
  </div>
</div>
