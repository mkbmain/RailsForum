<div class="max-w-md mx-auto mt-12 p-6 bg-white rounded-lg shadow">
  <h1 class="text-2xl font-bold mb-6">Log In</h1>

  <%= form_with url: login_path, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, class: "mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
    </div>
    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
      <%= f.password_field :password, class: "mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
    </div>
    <%= f.submit "Log In", class: "w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 font-medium" %>
  <% end %>

  <div class="mt-4 space-y-2">
    <%= button_to "Sign in with Google", "/auth/google_oauth2",
          class: "w-full bg-red-500 text-white py-2 px-4 rounded-md hover:bg-red-600 font-medium" %>
    <%= button_to "Sign in with Microsoft", "/auth/microsoft_graph",
          class: "w-full bg-blue-800 text-white py-2 px-4 rounded-md hover:bg-blue-900 font-medium" %>
  </div>

  <p class="mt-4 text-center text-sm text-gray-600">
    No account? <%= link_to "Sign up", signup_path, class: "text-blue-600 hover:underline" %>
  </p>
</div>
