<%# app/views/bans/new.html.erb %>
<div class="max-w-lg mx-auto mt-8 px-4">
  <h1 class="text-2xl font-bold mb-6">Ban <%= @target_user.name %></h1>

  <%= form_tag user_bans_path(@target_user), method: :post, class: "space-y-4 bg-white border border-stone-200 rounded-xl p-6" do %>

    <div>
      <%= label_tag :ban_reason_id, "Reason", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= select_tag :ban_reason_id,
            options_from_collection_for_select(@ban_reasons, :id, :name),
            prompt: "Select a reason",
            class: "w-full border border-stone-300 rounded-md px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= label_tag :duration_hours,
            @max_hours ? "Duration (hours, max #{@max_hours})" : "Duration (hours)",
            class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= number_field_tag :duration_hours, 24,
            min: 1, max: @max_hours,
            class: "w-full border border-stone-300 rounded-md px-3 py-2 text-sm" %>
    </div>

    <%= submit_tag "Issue Ban",
          class: "bg-red-600 text-white font-semibold rounded-lg px-4 py-2 hover:bg-red-700" %>
    <%= link_to "Cancel", root_path, class: "ml-3 text-sm text-stone-500 hover:underline" %>
  <% end %>
</div>
